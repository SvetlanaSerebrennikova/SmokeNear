# Copy to `.env.test` and fill locally only (`.env.test` is gitignored).
# In GitHub Actions use repository secrets instead — see README → CI/CD Setup.

APP_URL=https://near.com

# Required for wallet-chain E2E (WalletConnect bridge signs as this EVM key).
WALLETCONNECT_PROJECT_ID=
EVM_PRIVATE_KEY=

# Optional overrides (non-secret defaults live in `.env.test.defaults`).
# NEAR_WALLETCONNECT_ACCOUNT=your.near
# TEST_INTENTS_ACCOUNT_ID=your.near
# TEST_ONECLICK_STATUS_POLL=0

# Committed defaults merged after `.env.test` (only keys not already set).
# Secrets (WALLETCONNECT_PROJECT_ID, EVM_PRIVATE_KEY) stay in local `.env.test`.

APP_URL=https://near.com
# Public check: EVM_PRIVATE_KEY must derive to this address (see scripts/verify-wallet-env.mjs).
TEST_EVM_EXPECTED_ADDRESS=0xC7f5E984238CDc27c2FDC598B1eFE89870dCFc19
NEAR_WALLETCONNECT_ACCOUNT=relay.tg
TEST_INTENTS_ACCOUNT_ID=relay.tg
# Full swap + 1Click SUCCESS poll is opt-in (slow / needs deposit resolution).
TEST_ONECLICK_STATUS_POLL=0
